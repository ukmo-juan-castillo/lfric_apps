{% do LOG.debug("Entered site/esnz/common/suite_config_cascade.cylc") %}

{% set cascade_export_source = '. /esi/project/niwa00001/spack/share/spack/setup-env.sh ; '~
                               'spack load fcm@2021.05.0 /qcebcci ; ' %}

{% set cascade_plot = '. /opt/niwa/profile/conda_24.11.3_2025.05.1.sh ; '~
                      'conda activate niwa_python313_2025.05.1 ; ' %}

{% set cascade_modules_ifx = '. /esi/project/niwa00001/spack/share/spack/setup-env.sh ; '~
                             'spack load fcm@2021.05.0 /qcebcci ; '~
                             'spack load intel-oneapi-compilers@2025.3.2 /qw6qnl6 ; '~
                             'spack load intel-oneapi-mpi@2021.15.0 %oneapi@2025.3.2 /bj5int7 ; '~
                             'spack load py-psyclone@3.2.2 /iqx6uet ; '~
                             'spack load py-jinja2@3.1.4 /etihymc ; '~
                             'spack load rose-picker@2.1.0.dev0 /j6jwmly ; '~
                             'spack load py-pyyaml /dc2pxh2  ; ' %}

{% set cascade_build_setup_ifx = 'export FC=mpif90 FPP="cpp -P -x f95-cpp-input" CXX=icpx LDMPI=mpif90 VERBOSE=1 PSYCLONE_TRANSFORMATION=minimum ; '~
                                 'export PSYCLONE_CONFIG=$(spack location -i py-psyclone@3.2.2 /iqx6uet)/share/psyclone/psyclone.cfg ; '~
                                 'export YAXT_ROOT=$(spack location -i yaxt@0.11.5.1 %intel@2021.10.0 /n4z2cmm) ; '~
                                 'export XIOS_ROOT=$(spack location -i xios@2701 %intel@2021.10.0 /ueycp26) ; '~
                                 'export OASIS_ROOT=$(spack location -i oasis@3-mct5.0 %intel@2021.10.0 /awot3pa) ; '~
                                 'export NETCDF_FORTRAN_ROOT=$(spack location -i netcdf-fortran@4.6.1 %intel@2021.10.0 /nz665uw) ; '~
                                 'export NETCDF_C_ROOT=$(spack location -i netcdf-c@4.9.2 %intel@2021.10.0 /iqzbdoi) ; '~
                                 'export SHUMLIB_ROOT=$(spack location -i shumlib@um13.0 %intel@2021.10.0) ; '~
                                 'export INTEL_FORTRAN_ROOT=$(spack location -i intel-oneapi-compilers@2025.3.2 /qw6qnl6) ; '~
                                 'export PFUNIT=$(spack location -i pfunit@4.15.0 /67sdpsn)/PFUNIT-4.15 ; '~
                                 'export FFLAGS="-I$NETCDF_FORTRAN_ROOT/include -I$YAXT_ROOT/include -I$XIOS_ROOT/include '~
                                 '               -I$SHUMLIB_ROOT/include -I$PFUNIT/include -I$OASIS_ROOT/include -march=core-avx2" ; '~
                                 'export LDFLAGS="-L$XIOS_ROOT/lib -L$YAXT_ROOT/lib -Wl,-rpath=$YAXT_ROOT/lib '~
                                 '                -L$NETCDF_FORTRAN_ROOT/lib -Wl,-rpath=$NETCDF_FORTRAN_ROOT/lib '~
                                 '                -L$NETCDF_C_ROOT/lib -Wl,-rpath=$NETCDF_C_ROOT/lib '~
                                 '                -L$SHUMLIB_ROOT/lib -Wl,-rpath=$SHUMLIB_ROOT/lib '~
                                 '                -L$OASIS_ROOT/lib -Wl,-rpath=$OASIS_ROOT/lib '~
                                 '                -shared-intel -lirng" ; ' %}

{% set cascade_run_ifx = '. /esi/project/niwa00001/spack/share/spack/setup-env.sh ; '~
                         'spack load intel-oneapi-mpi@2021.15.0 %oneapi@2025.3.2 /bj5int7 ; ' %}

[scheduling]

    [[queues]]
        [[[build_on_cascade]]]
            limit = 2
            members = CASCADE_BUILD_IFX

[runtime]

    [[CASCADE_BASE]]
        [[[environment]]]
            SITE = 'esnz'
            UMDIR = /opt/niwa/um_sys/um
            BUILD_ROOT = ${CYLC_TASK_WORK_DIR}/${CYLC_WORKFLOW_NAME_BASE}_${USER}_cascade
            SOURCE_ROOT = $CYLC_WORKFLOW_SHARE_DIR/source
            OUTPUT_ROOT = $CYLC_WORKFLOW_SHARE_DIR/output_cascade

    [[CASCADE_BG]]
        inherit = CASCADE_BASE
        platform = niwa-build01-background

    [[CASCADE_PBS]]
        inherit = CASCADE_BASE
        platform = cascade-pbs
        [[[directives]]]
            -q = shortq

    [[CASCADE_BUILD_IFX]]
        inherit = CASCADE_BG
        {{ generate_script("pre-script", [cascade_modules_ifx, cascade_build_setup_ifx]) }}
        [[[environment]]]
            USE_MPI_F08 = "use_mpi_f08"

    [[CASCADE_RUN_IFX]]
        inherit = CASCADE_PBS
        {{ generate_script("pre-script", [cascade_run_ifx]) }}
        [[[environment]]]
            RUN_METHOD = mpiexec
            HYPERTHREADS = 1
            CORES_PER_NODE = 192
            NUMA_REGIONS_PER_NODE = 2
            OMP_STACKSIZE = 1G
            BIG_DATA_DIR = '/opt/niwa/um_sys/lfric/data'
            TARGET_PLATFORM = 'esnz-cascade'

    [[CASCADE_MESH_IFX]]
        inherit = CASCADE_PBS
        {{ generate_script("pre-script", [cascade_run_ifx]) }}

    [[CASCADE_TECH_TESTS_IFX]]
        inherit = CASCADE_BG

    [[CASCADE_PLOT]]
        inherit = CASCADE_BG
        {{ generate_script("pre-script", [cascade_plot]) }}
        [[[environment]]]
            OUTPUT_ROOT = $CYLC_WORKFLOW_SHARE_DIR/output_cascade

    [[CASCADE_CHECK]]
        inherit = CASCADE_BG
        # Skip KGO checks for now
        pre-script = "echo 'Skipping KGO checks'; exit 0"

    [[CASCADE_SCRIPTS]]
        inherit = CASCADE_BG
        pre-script = """
                     . /opt/niwa/profile/conda_24.11.3_2025.05.1.sh
                     conda activate /esi/project/niwa00001/rose-stem-env
                     export PYTHONPATH=/esi/project/niwa00001/rose-stem-env/lib/python3.13/site-packages
                     """

    [[CASCADE_EXPORT-SOURCE]]
        inherit = CASCADE_BG
        post-script = """
                      sed -i 's/-check all/-check all -check noarg_temp_created/' ${SOURCE_ROOT}/lfric_core/infrastructure/build/fortran/ifx.mk
                      sed -i 's/-fpe0/-fpe3/' ${SOURCE_ROOT}/lfric_core/infrastructure/build/fortran/ifx.mk
                      sed -i 's/-fpe0/-fpe3/' ${SOURCE_ROOT}/lfric_apps/applications/lfric_atm/build/fortran/ifx.mk
                      """
        [[[environment]]]
            PLATFORM_SYNC = false

    [[CASCADE_ROSE_ANA]]
        inherit = CASCADE_BG
        pre-script = ". /opt/niwa/profile/conda_24.11.3_2025.05.1.sh ; conda activate niwa_tools_2025.07.1 ;"

    [[CASCADE_WEIGHTS]]
        inherit = CASCADE_PBS
        pre-script = ". /opt/niwa/profile/conda_24.11.3_2025.05.1.sh ; conda activate niwa_tools_2025.07.1 ;"

    [[EXPORT-SOURCE]]
        inherit = CASCADE_BG
        {{ generate_script("pre-script", [cascade_export_source]) }}

    [[CASCADE_HOUSEKEEPING]]
        inherit=CASCADE_BG

{% do LOG.debug("Finished in site/esnz/common/suite_config_cascade.cylc") %}
