!> Test the upwind_tracer_flux_kernel_mod
!>
module upwind_tracer_flux_kernel_mod_test

  use constants_mod, only : i_def, r_def
  use funit

  implicit none

  private
  public :: upwind_tracer_flux_kernel_test_type, test_all

  @TestCase
  type, extends(TestCase) :: upwind_tracer_flux_kernel_test_type
    private
  contains
    procedure test_all
  end type upwind_tracer_flux_kernel_test_type

contains
  !!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!
  @Test
  subroutine test_all( this )

    use upwind_tracer_flux_kernel_mod, only : upwind_tracer_flux_code

    implicit none

    class(upwind_tracer_flux_kernel_test_type), intent(inout) :: this

    integer(kind=i_def), parameter :: nlayers = 3
    integer(kind=i_def), parameter :: ndf_w3 = 1
    integer(kind=i_def), parameter :: undf_w3 = nlayers * ndf_w3
    integer(kind=i_def), parameter :: ndf_w2 = 6
    integer(kind=i_def), parameter :: undf_w2 = 5 * nlayers + 1

    integer(kind=i_def)            :: map_w3(ndf_w3)
    integer(kind=i_def)            :: map_w2(ndf_w2)
    real(kind=r_def)               :: tracer_flux(undf_w2)
    real(kind=r_def)               :: dry_flux(undf_w2)
    real(kind=r_def)               :: tracer_field(undf_w3)
    real(kind=r_def)               :: tracer_flux_answer(undf_w2)

    real(kind=r_def), parameter    :: tol = 1.0e-12_r_def

    map_w3(:) = (/ 1_i_def /)
    map_w2(:) = (/                                                             &
        1, 1+nlayers, 1+2*nlayers, 1+3*nlayers, 1+4*nlayers, 2+4*nlayers       &
    /)

    tracer_flux(:) = 0.0_r_def
    dry_flux(:) = (/                                                           &
        -2.0_r_def, -2.0_r_def, -2.0_r_def,                                    &
         3.0_r_def,  3.0_r_def,  3.0_r_def,                                    &
        -4.0_r_def, -4.0_r_def, -4.0_r_def,                                    &
         5.0_r_def,  5.0_r_def,  5.0_r_def,                                    &
         0.0_r_def, -6.0_r_def, -6.0_r_def, 0.0_r_def                          &
    /)
    tracer_field(:) = (/ 0.5_r_def, 1.0_r_def, 1.5_r_def /)

    tracer_flux_answer(:) = (/                                                 &
        -1.0_r_def,  -2.0_r_def,  -3.0_r_def,                                  &
         1.5_r_def,   3.0_r_def,   4.5_r_def,                                  &
         0.0_r_def,   0.0_r_def,   0.0_r_def,                                  &
         0.0_r_def,   0.0_r_def,   0.0_r_def,                                  &
         0.0_r_def,  -6.0_r_def,  -9.0_r_def, 0.0_r_def                        &
    /)

    call upwind_tracer_flux_code(                                              &
        nlayers,                                                               &
        tracer_flux,                                                           &
        dry_flux,                                                              &
        tracer_field,                                                          &
        ndf_w2, undf_w2, map_w2,                                               &
        ndf_w3, undf_w3, map_w3                                                &
    )

    @assertEqual(tracer_flux, tracer_flux_answer, tol)

  end subroutine test_all

end module upwind_tracer_flux_kernel_mod_test
