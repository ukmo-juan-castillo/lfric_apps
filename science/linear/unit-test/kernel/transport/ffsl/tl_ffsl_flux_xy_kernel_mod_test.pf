!> @brief Test the tracer 1D TL FFSL flux computation in the horizontal

module tl_ffsl_flux_xy_kernel_mod_test

  use constants_mod, only : i_def, r_tran
  use funit

  implicit none

  private

  public :: test_all

contains

 !!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!
  @Test
  subroutine test_all( )

    use, intrinsic :: iso_fortran_env,  only: real64
    use tl_ffsl_flux_xy_kernel_mod,     only: tl_ffsl_flux_xy_code

    implicit none

    real(kind=r_tran), parameter :: tol = 1.0e-12_r_tran   ! r_tran 64-bit
    real(kind=r_tran)            :: answer_pert, answer_ls, use_tol

    integer(kind=i_def), parameter :: nlayers = 1
    integer(kind=i_def), parameter :: ndf_w3 = 1
    integer(kind=i_def), parameter :: ndf_w3_2d = 1
    integer(kind=i_def), parameter :: ndf_w2 = 4
    integer(kind=i_def), parameter :: stencil_max = 5
    integer(kind=i_def), parameter :: undf_w2 = ndf_w2*nlayers
    integer(kind=i_def), parameter :: undf_w3 = ndf_w3*nlayers*(2*stencil_max-1)
    integer(kind=i_def), parameter :: undf_w3_2d = ndf_w3*nlayers
    integer(kind=i_def), parameter :: order = 2
    real(kind=r_tran),   parameter :: min_val = 0.0_r_tran
    integer(kind=i_def), parameter :: ndep = 2*stencil_max-1
    integer(kind=i_def), parameter :: ndf_depk = 4
    integer(kind=i_def), parameter :: ndep_half = (ndep - 1) / 2
    integer(kind=i_def), parameter :: undf_depk = ndf_depk*ndep

    integer(kind=i_def), dimension(ndf_w3)               :: map_w3
    integer(kind=i_def), dimension(ndf_w3_2d)            :: map_w3_2d
    integer(kind=i_def), dimension(ndf_w2)               :: map_w2
    integer(kind=i_def), dimension(ndf_depk)             :: map_depk
    integer(kind=i_def), dimension(4)                    :: stencil_sizes
    integer(kind=i_def), dimension(ndf_w3,stencil_max,4) :: stencil_map

    real(kind=r_tran),   dimension(undf_w3)    :: field_for_x
    real(kind=r_tran),   dimension(undf_w3)    :: field_for_y
    real(kind=r_tran),   dimension(undf_w3)    :: ls_field_for_x
    real(kind=r_tran),   dimension(undf_w3)    :: ls_field_for_y
    real(kind=r_tran),   dimension(undf_w2)    :: dep_pts
    real(kind=r_tran),   dimension(undf_w2)    :: flux_pert
    real(kind=r_tran),   dimension(undf_w2)    :: flux_ls
    real(kind=r_tran),   dimension(undf_w3)    :: dry_mass_for_x
    real(kind=r_tran),   dimension(undf_w3)    :: dry_mass_for_y
    real(kind=r_tran),   dimension(undf_w2)    :: frac_dry_flux
    real(kind=r_tran),   dimension(undf_w2)    :: frac_dry_pert
    integer(kind=i_def), dimension(undf_w3_2d) :: face_selector_ew
    integer(kind=i_def), dimension(undf_w3_2d) :: face_selector_ns
    integer(kind=i_def), dimension(undf_depk)  :: dep_lowest_k
    integer(kind=i_def), dimension(undf_depk)  :: dep_highest_k

    real(kind=r_tran)   :: dt

    ! Set up maps
    stencil_sizes(:) = stencil_max
    stencil_map(:,:,:) = reshape(                                              &
        (/ 5, 4, 3, 2, 1,    5, 4, 3, 2, 1,                                    &
           5, 6, 7, 8, 9,    5, 6, 7, 8, 9 /), [1, stencil_max, 4] )
    map_w2(:) = (/ 1, 2, 3, 4 /)
    map_w3(1) = 5
    map_w3_2d(1) = 1
    map_depk(:) = (/ 1, 10, 19, 28 /)

    ! Set up field to have quadratic profile
    field_for_x(:) = (/ 17.0_r_tran, 10.0_r_tran, 5.0_r_tran, &
                        2.0_r_tran,  1.0_r_tran,  2.0_r_tran, &
                        5.0_r_tran,  10.0_r_tran, 17.0_r_tran /)

    field_for_y(:) = (/ 17.0_r_tran, 10.0_r_tran, 5.0_r_tran, &
                        2.0_r_tran,  1.0_r_tran,  2.0_r_tran, &
                        5.0_r_tran,  10.0_r_tran, 17.0_r_tran /)

    ! Set up ls_field to have linear profile
    ls_field_for_x(:) = (/ 5.0_r_tran, 4.0_r_tran, 3.0_r_tran, &
                           2.0_r_tran, 1.0_r_tran, 2.0_r_tran, &
                           3.0_r_tran, 4.0_r_tran, 5.0_r_tran /)

    ls_field_for_y(:) = (/ 5.0_r_tran, 4.0_r_tran, 3.0_r_tran, &
                           2.0_r_tran, 1.0_r_tran, 2.0_r_tran, &
                           3.0_r_tran, 4.0_r_tran, 5.0_r_tran /)

    ! Initialise fluxes to zero before each test
    flux_pert(:) = 0.0_r_tran
    flux_ls(:) = 0.0_r_tran

    ! Set face selctor to compute fluxes at all horizontal faces
    face_selector_ew(:) = 2
    face_selector_ns(:) = 2

    ! Dry density and volume
    dry_mass_for_x(:) = 3.0_r_tran
    dry_mass_for_y(:) = 3.0_r_tran

    ! Set up departure point indices
    dep_lowest_k(:) = 0  ! Default is to not include any layers
    dep_highest_k(:) = -1  ! Default is to not include any layers
    dep_highest_k(map_depk(1) + ndep_half - 1) = 0
    dep_highest_k(map_depk(2) + ndep_half) = 0
    dep_highest_k(map_depk(3) + ndep_half) = 0
    dep_highest_k(map_depk(4) + ndep_half + 1) = 0

    ! Set departure distances and winds
    dep_pts(:) = 0.4_r_tran
    frac_dry_flux(:) = 1.2_r_tran
    frac_dry_pert(:) = 1.0_r_tran
    dt = 2.0_r_tran

    ! Call kernel
    call tl_ffsl_flux_xy_code( nlayers,          &
                               flux_pert,        &
                               flux_ls,          &
                               field_for_x,      &
                               stencil_sizes,    &
                               stencil_max,      &
                               stencil_map,      &
                               dry_mass_for_x,   &
                               stencil_sizes,    &
                               stencil_max,      &
                               stencil_map,      &
                               field_for_y,      &
                               stencil_sizes,    &
                               stencil_max,      &
                               stencil_map,      &
                               dry_mass_for_y,   &
                               stencil_sizes,    &
                               stencil_max,      &
                               stencil_map,      &
                               ls_field_for_x,   &
                               stencil_sizes,    &
                               stencil_max,      &
                               stencil_map,      &
                               ls_field_for_y,   &
                               stencil_sizes,    &
                               stencil_max,      &
                               stencil_map,      &
                               dep_pts,          &
                               frac_dry_flux,    &
                               frac_dry_pert,    &
                               dep_lowest_k,     &
                               dep_highest_k,    &
                               face_selector_ew, &
                               face_selector_ns, &
                               order,            &
                               ndep,             &
                               dt,               &
                               ndf_w2,           &
                               undf_w2,          &
                               map_w2,           &
                               ndf_w3,           &
                               undf_w3,          &
                               map_w3,           &
                               ndf_depk,         &
                               undf_depk,        &
                               map_depk,         &
                               ndf_w3_2d,        &
                               undf_w3_2d,       &
                               map_w3_2d )

    ! Get correct tolerance
    if ( r_tran == real64 ) then
      use_tol = tol
    else
      use_tol = 10.0_r_tran*spacing( maxval( flux_pert(1:4) ) )
    end if

    ! flux_pert is computed using the PPM reconstruction with a stencil
    ! composed of field_for_x and field_for_y for x and y fluxes respectively
    ! It is computed as frac_dry_flux*field_reconstruction(dep_cell)/dt
    answer_pert = 0.852_r_tran
    @assertEqual(answer_pert, flux_pert(1), use_tol)
    answer_pert = 0.612_r_tran
    @assertEqual(answer_pert, flux_pert(2), use_tol)
    answer_pert = 0.612_r_tran
    @assertEqual(answer_pert, flux_pert(3), use_tol)
    answer_pert = 0.852_r_tran
    @assertEqual(answer_pert, flux_pert(4), use_tol)

    ! flux_ls is computed using the ls_field value (ls_field_for_x and
    ! ls_field_for_y for x and y fluxes respectivelyl) in the departure
    ! cell (determined by dep_pts), ls_field(dep_cell)*frac_dry_pert/dt
    answer_ls = 1.0_r_tran
    @assertEqual(answer_ls, flux_ls(1), use_tol)
    answer_ls = 0.5_r_tran
    @assertEqual(answer_ls, flux_ls(2), use_tol)
    answer_ls = 0.5_r_tran
    @assertEqual(answer_ls, flux_ls(3), use_tol)
    answer_ls = 1.0_r_tran
    @assertEqual(answer_ls, flux_ls(4), use_tol)

  end subroutine test_all

end module tl_ffsl_flux_xy_kernel_mod_test
