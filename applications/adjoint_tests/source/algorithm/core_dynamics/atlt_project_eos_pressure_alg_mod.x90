!> @brief Module containing adjoint test for atl_project_eos_pressure_kernel
module atlt_project_eos_pressure_alg_mod

  use sci_assign_field_random_range_alg_mod, &
                                     only : assign_field_random_range
  use field_mod,                     only : field_type
  use function_space_mod,            only : function_space_type
  use mesh_mod,                      only : mesh_type
  use function_space_collection_mod, only : function_space_collection
  use finite_element_config_mod,     only : element_order_h, element_order_v
  use fs_continuity_mod,             only : W0, W3, Wtheta
  use operator_mod,                  only : operator_type
  use quadrature_xyoz_mod,           only : quadrature_xyoz_type
  use constants_mod,                 only : i_def, r_def
  use quadrature_rule_gaussian_mod,  only : quadrature_rule_gaussian_type
  use setop_random_alg_mod,          only : setop_random_alg
  use log_mod,                       only : log_event,         &
                                            log_scratch_space, &
                                            LOG_LEVEL_ERROR,   &
                                            LOG_LEVEL_INFO,    &
                                            LOG_LEVEL_DEBUG
  use adjoint_test_parameters_mod,   only : ls_rho_range,   &
                                            ls_theta_range, &
                                            ls_md1_range

  implicit none

  public :: atlt_project_eos_pressure_alg

  contains
  !=============================================================================
  !> @brief   Adjoint test for atl_project_eos_pressure.
  !> @details Passes if adjoint is transpose of tangent linear.
  !>          Determined by testing the equality of inner products <Mx, Mx> and <AMx, x>,
  !>          where M is the tangent linear and A is the adjoint.
  !> @param[in] mesh        Mesh object
  !> @param[in] chi         Coordinate field
  !> @param[in] panel_id    ID of panel
  subroutine atlt_project_eos_pressure_alg( mesh, chi, panel_id )

    use tl_project_eos_pressure_kernel_mod,  only : tl_project_eos_pressure_kernel_type
    use atl_project_eos_pressure_kernel_mod, only : atl_project_eos_pressure_kernel_type

    implicit none

    ! Arguments
    type(mesh_type), pointer,       intent(in) :: mesh
    type(field_type), dimension(3), intent(in) :: chi
    type(field_type),               intent(in) :: panel_id

    ! Arguments for tl and adj calls
    type(field_type) :: exner
    type(field_type) :: rho
    type(field_type) :: theta
    type(field_type) :: moist_dyn_gas
    type(field_type) :: ls_rho
    type(field_type) :: ls_theta
    type(field_type) :: ls_moist_dyn_gas
    type(operator_type) :: m3_inv
    type(quadrature_xyoz_type) :: qr_xyoz

    ! Copies of input fields used in inner products
    type(field_type) :: exner_input
    type(field_type) :: rho_input
    type(field_type) :: theta_input
    type(field_type) :: moist_dyn_gas_input

    ! Pointers for initialising fields
    type(function_space_type), pointer :: vector_space_w0_ptr
    type(function_space_type), pointer :: vector_space_w3_ptr
    type(function_space_type), pointer :: vector_space_wtheta_ptr

    ! Inner products
    real(kind=r_def) :: exner_inner_prod
    real(kind=r_def) :: rho_inner_prod
    real(kind=r_def) :: theta_inner_prod
    real(kind=r_def) :: moist_dyn_gas_inner_prod
    real(kind=r_def) :: exner_sf
    real(kind=r_def) :: rho_sf
    real(kind=r_def) :: theta_sf
    real(kind=r_def) :: moist_dyn_gas_sf
    real(kind=r_def) :: inner1
    real(kind=r_def) :: exner_exner_input_inner_prod
    real(kind=r_def) :: rho_rho_input_inner_prod
    real(kind=r_def) :: theta_theta_input_inner_prod
    real(kind=r_def) :: moist_dyn_gas_moist_dyn_gas_input_inner_prod
    real(kind=r_def) :: inner2

    ! Test parameters and variables
    real(kind=r_def), parameter :: overall_tolerance = 1500.0_r_def
    real(kind=r_def)            :: machine_tol
    real(kind=r_def)            :: relative_diff
    real(kind=r_def), parameter :: eps = 1.0e-30_r_def

    ! Misc
    type(quadrature_rule_gaussian_type) :: quadrature_rule

    vector_space_w0_ptr => function_space_collection%get_fs(mesh, element_order_h, element_order_v, W0)
    vector_space_w3_ptr => function_space_collection%get_fs(mesh, element_order_h, element_order_v, W3)
    vector_space_wtheta_ptr => function_space_collection%get_fs(mesh, element_order_h, element_order_v, Wtheta)
    call exner%initialise(vector_space=vector_space_w3_ptr, name='exner')
    call rho%initialise(vector_space=vector_space_w3_ptr, name='rho')
    call theta%initialise(vector_space=vector_space_wtheta_ptr, name='theta')
    call moist_dyn_gas%initialise(vector_space=vector_space_wtheta_ptr, name='moist_dyn_gas')
    call ls_rho%initialise(vector_space=vector_space_w3_ptr, name='ls_rho')
    call ls_theta%initialise(vector_space=vector_space_wtheta_ptr, name='ls_theta')
    call ls_moist_dyn_gas%initialise(vector_space=vector_space_wtheta_ptr, name='ls_moist_dyn_gas')
    call m3_inv%initialise(vector_space_w3_ptr, vector_space_w3_ptr)
    qr_xyoz = quadrature_xyoz_type(element_order_h + 3,element_order_h + 3,element_order_v + 3,quadrature_rule)

    call exner%copy_field_properties(exner_input)
    call rho%copy_field_properties(rho_input)
    call theta%copy_field_properties(theta_input)
    call moist_dyn_gas%copy_field_properties(moist_dyn_gas_input)

    exner_inner_prod = 0.0_r_def
    rho_inner_prod = 0.0_r_def
    theta_inner_prod = 0.0_r_def
    moist_dyn_gas_inner_prod = 0.0_r_def

    ! Initialise arguments and call the tangent-linear kernel.
    call invoke( setval_random(exner), setval_x(exner_input, exner), &
                 setval_random(rho), setval_x(rho_input, rho),       &
                 setval_random(theta), setval_x(theta_input, theta), &
                 setval_random(moist_dyn_gas), setval_x(moist_dyn_gas_input, moist_dyn_gas) )

    call setop_random_alg( m3_inv )
    call assign_field_random_range( ls_rho, ls_rho_range(1), ls_rho_range(2) )
    call assign_field_random_range( ls_theta, ls_theta_range(1), ls_theta_range(2) )
    call assign_field_random_range( ls_moist_dyn_gas, ls_md1_range(1), ls_md1_range(2) )

    ! < Mx, Mx >
    call invoke( tl_project_eos_pressure_kernel_type(exner, rho, theta, moist_dyn_gas,   &
                                                     ls_rho, ls_theta, ls_moist_dyn_gas, &
                                                     chi, panel_id,                      &
                                                     m3_inv, qr_xyoz),                   &
                 x_innerproduct_x(exner_inner_prod, exner),                              &
                 x_innerproduct_x(rho_inner_prod, rho),                                  &
                 x_innerproduct_x(theta_inner_prod, theta),                              &
                 x_innerproduct_x(moist_dyn_gas_inner_prod, moist_dyn_gas) )

    write( log_scratch_space, * ) "atlt_project_eos_pressure inner products:"
    call log_event( log_scratch_space, LOG_LEVEL_DEBUG )
    write( log_scratch_space, * ) "moist_dyn_gas inner product = ", moist_dyn_gas_inner_prod
    call log_event( log_scratch_space, LOG_LEVEL_DEBUG )
    write( log_scratch_space, * ) "exner inner product = ", exner_inner_prod
    call log_event( log_scratch_space, LOG_LEVEL_DEBUG )
    write( log_scratch_space, * ) "rho inner product = ", rho_inner_prod
    call log_event( log_scratch_space, LOG_LEVEL_DEBUG )
    write( log_scratch_space, * ) "theta inner product = ", theta_inner_prod
    call log_event( log_scratch_space, LOG_LEVEL_DEBUG )

    moist_dyn_gas_sf = 1.0_r_def / (moist_dyn_gas_inner_prod + eps)
    exner_sf = 1.0_r_def / (exner_inner_prod + eps)
    rho_sf = 1.0_r_def / (rho_inner_prod + eps)
    theta_sf = 1.0_r_def / (theta_inner_prod + eps)

    inner1 = 0.0_r_def
    inner1 = inner1 + moist_dyn_gas_inner_prod * moist_dyn_gas_sf
    inner1 = inner1 + exner_inner_prod * exner_sf
    inner1 = inner1 + rho_inner_prod * rho_sf
    inner1 = inner1 + theta_inner_prod * theta_sf

    ! Scaling fields
    call invoke( inc_a_times_X( moist_dyn_gas_sf, moist_dyn_gas ), &
                 inc_a_times_X( exner_sf, exner ),                 &
                 inc_a_times_X( rho_sf, rho ),                     &
                 inc_a_times_X( theta_sf, theta ) )

    exner_exner_input_inner_prod = 0.0_r_def
    rho_rho_input_inner_prod = 0.0_r_def
    theta_theta_input_inner_prod = 0.0_r_def
    moist_dyn_gas_moist_dyn_gas_input_inner_prod = 0.0_r_def

    ! < AMx, x >
    call invoke( atl_project_eos_pressure_kernel_type(exner, rho, theta, moist_dyn_gas,   &
                                                      ls_rho, ls_theta, ls_moist_dyn_gas, &
                                                      chi, panel_id,                      &
                                                      m3_inv, qr_xyoz),                   &
                 x_innerproduct_y(exner_exner_input_inner_prod, exner, exner_input),      &
                 x_innerproduct_y(rho_rho_input_inner_prod, rho, rho_input),              &
                 x_innerproduct_y(theta_theta_input_inner_prod, theta, theta_input),      &
                 x_innerproduct_y(moist_dyn_gas_moist_dyn_gas_input_inner_prod, moist_dyn_gas, moist_dyn_gas_input) )

    inner2 = 0.0_r_def
    inner2 = inner2 + exner_exner_input_inner_prod
    inner2 = inner2 + rho_rho_input_inner_prod
    inner2 = inner2 + theta_theta_input_inner_prod
    inner2 = inner2 + moist_dyn_gas_moist_dyn_gas_input_inner_prod

    ! Test the inner-product values for equality, allowing for the precision of the active variables
    machine_tol = spacing(max(abs(inner1), abs(inner2)))
    relative_diff = abs(inner1 - inner2) / machine_tol
    if (relative_diff < overall_tolerance) then
      write(log_scratch_space, *) "PASSED tl_project_eos_pressure_kernel_type:", inner1, inner2, relative_diff
      call log_event(log_scratch_space, LOG_LEVEL_INFO)
    else
      write(log_scratch_space, *) "FAILED tl_project_eos_pressure_kernel_type:", inner1, inner2, relative_diff
      call log_event(log_scratch_space, LOG_LEVEL_ERROR)
    end if

  end subroutine atlt_project_eos_pressure_alg

end module atlt_project_eos_pressure_alg_mod
